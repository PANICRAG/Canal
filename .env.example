# ==========================================
# AI Gateway Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ==========================================
# REQUIRED - Database (Supabase PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# For connection pooling (recommended for production):
# DATABASE_POOLER_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# ==========================================
# REQUIRED - Vector Database (Qdrant)
# ==========================================
QDRANT_URL=https://YOUR_CLUSTER.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# ==========================================
# REQUIRED - LLM Providers
# ==========================================
# Anthropic (primary)
ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI (fallback)
OPENAI_API_KEY=sk-your-key

# Optional: Google AI
# GOOGLE_API_KEY=your-google-api-key

# OpenRouter (for UI-TARS and other models)
OPENROUTER_API_KEY=sk-or-v1-your-key

# Qwen / Alibaba Cloud DashScope (primary)
QWEN_API_KEY=your-qwen-api-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# QWEN_DEFAULT_MODEL=qwen3-max-2026-01-23

# Optional: Local Ollama
# OLLAMA_URL=http://localhost:11434

# ==========================================
# REQUIRED - Authentication
# ==========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-256-bit-secret-key-here

# Salt for API key hashing
API_KEY_SALT=your-random-salt-here

# ==========================================
# SERVER CONFIGURATION
# ==========================================
# Server port
PORT=4000

# Host to bind to
HOST=0.0.0.0

# Environment (development, staging, production)
ENVIRONMENT=development

# Log level (trace, debug, info, warn, error)
RUST_LOG=info,gateway_core=debug,gateway_api=debug

# Dev mode: enables debug dashboard endpoints (/api/debug/*)
# Set to "true" in development, omit or "false" in production
DEV_MODE=true

# ==========================================
# OPTIONAL - Redis Cache
# ==========================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# ==========================================
# OPTIONAL - Monitoring & Alerting
# ==========================================
# Sentry error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Prometheus push gateway
# PROMETHEUS_PUSH_GATEWAY=http://prometheus-pushgateway:9091

# Slack webhook for alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ==========================================
# OPTIONAL - MCP Server Configuration
# ==========================================
# WebApp MCP Server
# WEBAPP_MCP_URL=http://localhost:3000

# Adobe MCP
# ADOBE_MCP_COMMAND=npx -y adobe-mcp

# DaVinci Resolve MCP
# DAVINCI_MCP_COMMAND=npx -y @samuelgursky/davinci-resolve-mcp

# ComfyUI MCP
# COMFYUI_MCP_URL=http://localhost:8000

# ==========================================
# OPTIONAL - OmniParser (ONNX element detection)
# ==========================================
# Path to directory containing ONNX model files
# OMNIPARSER_MODEL_DIR=models/omniparser

# ==========================================
# KUBERNETES DEPLOYMENT (set by K8s)
# ==========================================
# POD_NAME=
# POD_NAMESPACE=
# NODE_NAME=
