#!/usr/bin/env bash
set -e

echo "=== Pre-push checks ==="

echo "[1/4] cargo fmt --check"
cargo +nightly fmt --all -- --check 2>/dev/null || cargo fmt --all -- --check
echo "  ✓ Format OK"

echo "[2/4] cargo clippy"
cargo clippy --workspace --all-targets 2>&1 | grep "^error" && { echo "  ✗ Clippy errors found"; exit 1; } || echo "  ✓ Clippy OK"

echo "[3/4] cargo test"
cargo test --workspace -- --quiet
echo "  ✓ Tests OK"

echo "[4/4] typos"
if command -v typos &> /dev/null; then
    typos
    echo "  ✓ Typos OK"
else
    echo "  ⊘ typos not installed, skipping (install: cargo install typos-cli)"
fi

echo "=== All checks passed ==="
